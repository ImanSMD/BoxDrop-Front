# Backend base URL (include the /api/v1 path per CLAUDE.md §8)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Where Zarinpal redirects after a wallet top-up
NEXT_PUBLIC_ZARINPAL_RETURN_URL=http://localhost:3000/wallet/topup/callback

# When "true", the app serves data from the local mock layer (lib/api/mocks)
# instead of hitting the real backend. Lets every screen run standalone.
NEXT_PUBLIC_USE_MOCKS=true

# Web Push (optional, §11). Set to enable push subscription opt-in.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
